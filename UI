        refresh_action = QAction("Обновить", self)
        refresh_action.triggered.connect(self.load_data)
        file_menu.addAction(refresh_action)
        
        exit_action = QAction("Выход", self)
        exit_action.triggered.connect(self.close)
        file_menu.addAction(exit_action)
        
        help_menu = menubar.addMenu("Помощь")
        about_action = QAction("О программе", self)
        about_action.triggered.connect(self.show_about)
        help_menu.addAction(about_action)
        
        # Статус бар
        self.statusbar = QStatusBar()
        self.setStatusBar(self.statusbar)
        self.statusbar.showMessage("Готов")
        
    def load_data(self):
        try:
            conn = sqlite3.connect('coffee.sqlite')
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM coffee ORDER BY id")
            rows = cursor.fetchall()
            
            self.table.setRowCount(len(rows))
            
            for i, row in enumerate(rows):
                for j, value in enumerate(row):
                    if j == 5:
                        item = QTableWidgetItem(f"{value:.2f}")
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    elif j == 6:
                        item = QTableWidgetItem(str(value))
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    else:
                        item = QTableWidgetItem(str(value))
                    
                    if j == 0:
                        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsEditable)
                    
                    self.table.setItem(i, j, item)
            
            self.table.resizeColumnsToContents()
            self.statusbar.showMessage(f"Загружено {len(rows)} записей")
            conn.close()
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Ошибка", f"Ошибка базы данных: {e}")
            
    def apply_filters(self):
        try:
            conn = sqlite3.connect('coffee.sqlite')
            cursor = conn.cursor()
            
            query = "SELECT * FROM coffee WHERE 1=1"
            params = []
            
            search_text = self.search_input.text().strip()
            if search_text:
                query += " AND (name LIKE ? OR flavor_description LIKE ?)"
                params.extend([f"%{search_text}%", f"%{search_text}%"])
            
            roast = self.roast_filter.currentText()
            if roast != "Все":
                query += " AND roast_level = ?"
                params.append(roast)
            
            query += " ORDER BY id"
            
            cursor.execute(query, params)
            rows = cursor.fetchall()
            
            self.table.setRowCount(len(rows))
            
            for i, row in enumerate(rows):
                for j, value in enumerate(row):
                    if j == 5:
                        item = QTableWidgetItem(f"{value:.2f}")
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    elif j == 6:
                        item = QTableWidgetItem(str(value))
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    else:
                        item = QTableWidgetItem(str(value))
                    
                    if j == 0:
                        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsEditable)
                    
                    self.table.setItem(i, j, item)
            
            self.statusbar.showMessage(f"Найдено {len(rows)} записей")
            conn.close()
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Ошибка", f"Ошибка базы данных: {e}")
    
    def reset_filters(self):
        self.search_input.clear()
        self.roast_filter.setCurrentText("Все")
        self.load_data()
    
    def show_details(self, item):
        row = item.row()
        coffee_id = self.table.item(row, 0).text()
        
        try:
            conn = sqlite3.connect('coffee.sqlite')
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM coffee WHERE id = ?", (coffee_id,))
            row_data = cursor.fetchone()
            
            if row_data:
                self.detail_name.setText(row_data[1])
                self.detail_roast.setText(row_data[2])
                self.detail_grind.setText(row_data[3])
                self.detail_price.setText(f"{row_data[5]:.2f} руб")
                self.detail_volume.setText(f"{row_data[6]} г")
                self.detail_flavor.setText(row_data[4])
            
            conn.close()
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Ошибка", f"Ошибка базы данных: {e}")
    
    def show_about(self):
        QMessageBox.about(self, "О программе", 
                         "Кофе Каталог\nВерсия 1.0\n\nПрограмма для просмотра каталога кофе")


def main():
    app = QApplication(sys.argv)
    window = CoffeeApp()
    window.show()
    sys.exit(app.exec())

if __name__ == "__main__":
    main()
