        detail_layout.addWidget(QLabel("Название:"), 0, 0)
        detail_layout.addWidget(self.detail_name, 0, 1)
        detail_layout.addWidget(QLabel("Обжарка:"), 1, 0)
        detail_layout.addWidget(self.detail_roast, 1, 1)
        detail_layout.addWidget(QLabel("Тип:"), 2, 0)
        detail_layout.addWidget(self.detail_grind, 2, 1)
        detail_layout.addWidget(QLabel("Цена:"), 3, 0)
        detail_layout.addWidget(self.detail_price, 3, 1)
        detail_layout.addWidget(QLabel("Объем:"), 4, 0)
        detail_layout.addWidget(self.detail_volume, 4, 1)
        detail_layout.addWidget(QLabel("Описание вкуса:"), 5, 0, 1, 2)
