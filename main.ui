import sys
import sqlite3
from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, 
                            QHBoxLayout, QGroupBox, QLabel, QLineEdit, 
                            QComboBox, QPushButton, QTableWidget, QTableWidgetItem,
                            QTextEdit, QStatusBar, QMessageBox, QHeaderView,
                            QGridLayout)
from PyQt6.QtCore import Qt
from PyQt6.QtGui import QAction

class CoffeeApp(QMainWindow):
    def __init__(self):
        super().__init__()
        self.initUI()
        self.load_data()
        
    def initUI(self):
        self.setWindowTitle("Кофе Каталог")
        self.setGeometry(100, 100, 900, 600)
        
        # Центральный виджет
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        main_layout = QVBoxLayout(central_widget)
        
        # Группа фильтров
        filter_group = QGroupBox("Фильтры и поиск")
        filter_layout = QHBoxLayout(filter_group)
        
        self.search_input = QLineEdit()
        self.search_input.setPlaceholderText("Введите название или описание...")
        
        self.roast_filter = QComboBox()
        self.roast_filter.addItems(["Все", "Светлая", "Средняя", "Темная"])
        
        self.apply_btn = QPushButton("Применить")
        self.apply_btn.clicked.connect(self.apply_filters)
        
        self.reset_btn = QPushButton("Сбросить")
        self.reset_btn.clicked.connect(self.reset_filters)
        
        filter_layout.addWidget(QLabel("Поиск:"))
        filter_layout.addWidget(self.search_input)
        filter_layout.addWidget(QLabel("Обжарка:"))
        filter_layout.addWidget(self.roast_filter)
        filter_layout.addWidget(self.apply_btn)
        filter_layout.addWidget(self.reset_btn)
        
        main_layout.addWidget(filter_group)
        
        # Таблица
        self.table = QTableWidget()
        self.table.setAlternatingRowColors(True)
        self.table.setSelectionBehavior(QTableWidget.SelectionBehavior.SelectRows)
        self.table.setColumnCount(7)
        self.table.setHorizontalHeaderLabels([
            "ID", "Название", "Обжарка", "Тип", "Вкус", "Цена (руб)", "Объем (г)"
        ])
        self.table.horizontalHeader().setStretchLastSection(True)
        self.table.itemClicked.connect(self.show_details)
        
        main_layout.addWidget(self.table)
        
        # Группа детальной информации
        detail_group = QGroupBox("Детальная информация")
        detail_layout = QGridLayout(detail_group)
        
        self.detail_name = QLabel("-")
        self.detail_roast = QLabel("-")
        self.detail_grind = QLabel("-")
        self.detail_price = QLabel("-")
        self.detail_volume = QLabel("-")
        self.detail_flavor = QTextEdit()
        self.detail_flavor.setMaximumHeight(80)
        self.detail_flavor.setReadOnly(True)
        
        detail_layout.addWidget(QLabel("Название:"), 0, 0)
        detail_layout.addWidget(self.detail_name, 0, 1)
        detail_layout.addWidget(QLabel("Обжарка:"), 1, 0)
        detail_layout.addWidget(self.detail_roast, 1, 1)
        detail_layout.addWidget(QLabel("Тип:"), 2, 0)
        detail_layout.addWidget(self.detail_grind, 2, 1)
        detail_layout.addWidget(QLabel("Цена:"), 3, 0)
        detail_layout.addWidget(self.detail_price, 3, 1)
        detail_layout.addWidget(QLabel("Объем:"), 4, 0)
        detail_layout.addWidget(self.detail_volume, 4, 1)
        detail_layout.addWidget(QLabel("Описание вкуса:"), 5, 0, 1, 2)
        detail_layout.addWidget(self.detail_flavor, 6, 0, 1, 2)
        
        main_layout.addWidget(detail_group)
        
        # Меню
        menubar = self.menuBar()
        file_menu = menubar.addMenu("Файл")
        
        refresh_action = QAction("Обновить", self)
        refresh_action.triggered.connect(self.load_data)
        file_menu.addAction(refresh_action)
        
        exit_action = QAction("Выход", self)
        exit_action.triggered.connect(self.close)
        file_menu.addAction(exit_action)
        
        help_menu = menubar.addMenu("Помощь")
        about_action = QAction("О программе", self)
        about_action.triggered.connect(self.show_about)
        help_menu.addAction(about_action)
        
        # Статус бар
        self.statusbar = QStatusBar()
        self.setStatusBar(self.statusbar)
        self.statusbar.showMessage("Готов")
        
    def load_data(self):
        try:
            conn = sqlite3.connect('coffee.sqlite')
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM coffee ORDER BY id")
            rows = cursor.fetchall()
            
            self.table.setRowCount(len(rows))
            
            for i, row in enumerate(rows):
                for j, value in enumerate(row):
                    if j == 5:
                        item = QTableWidgetItem(f"{value:.2f}")
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    elif j == 6:
                        item = QTableWidgetItem(str(value))
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    else:
                        item = QTableWidgetItem(str(value))
                    
                    if j == 0:
                        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsEditable)
                    
                    self.table.setItem(i, j, item)
            
            self.table.resizeColumnsToContents()
            self.statusbar.showMessage(f"Загружено {len(rows)} записей")
            conn.close()
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Ошибка", f"Ошибка базы данных: {e}")
            
    def apply_filters(self):
        try:
            conn = sqlite3.connect('coffee.sqlite')
            cursor = conn.cursor()
            
            query = "SELECT * FROM coffee WHERE 1=1"
            params = []
            
            search_text = self.search_input.text().strip()
            if search_text:
                query += " AND (name LIKE ? OR flavor_description LIKE ?)"
                params.extend([f"%{search_text}%", f"%{search_text}%"])
            
            roast = self.roast_filter.currentText()
            if roast != "Все":
                query += " AND roast_level = ?"
                params.append(roast)
            
            query += " ORDER BY id"
            
            cursor.execute(query, params)
            rows = cursor.fetchall()
            
            self.table.setRowCount(len(rows))
            
            for i, row in enumerate(rows):
                for j, value in enumerate(row):
                    if j == 5:
                        item = QTableWidgetItem(f"{value:.2f}")
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    elif j == 6:
                        item = QTableWidgetItem(str(value))
                        item.setTextAlignment(Qt.AlignmentFlag.AlignRight)
                    else:
                        item = QTableWidgetItem(str(value))
                    
                    if j == 0:
                        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsEditable)
                    
                    self.table.setItem(i, j, item)
            
            self.statusbar.showMessage(f"Найдено {len(rows)} записей")
            conn.close()
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Ошибка", f"Ошибка базы данных: {e}")
    
    def reset_filters(self):
        self.search_input.clear()
        self.roast_filter.setCurrentText("Все")
        self.load_data()
    
    def show_details(self, item):
        row = item.row()
        coffee_id = self.table.item(row, 0).text()
        
        try:
            conn = sqlite3.connect('coffee.sqlite')
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM coffee WHERE id = ?", (coffee_id,))
            row_data = cursor.fetchone()
            
            if row_data:
                self.detail_name.setText(row_data[1])
                self.detail_roast.setText(row_data[2])
                self.detail_grind.setText(row_data[3])
                self.detail_price.setText(f"{row_data[5]:.2f} руб")
                self.detail_volume.setText(f"{row_data[6]} г")
                self.detail_flavor.setText(row_data[4])
            
            conn.close()
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Ошибка", f"Ошибка базы данных: {e}")
    
    def show_about(self):
        QMessageBox.about(self, "О программе", 
                         "Кофе Каталог\nВерсия 1.0\n\nПрограмма для просмотра каталога кофе")

def main():
    app = QApplication(sys.argv)
    window = CoffeeApp()
    window.show()
    sys.exit(app.exec())

if __name__ == "__main__":
    main()
