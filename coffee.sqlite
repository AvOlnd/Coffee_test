CREATE TABLE IF NOT EXISTS coffee (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    roast_level TEXT,
    grind_type TEXT,
    flavor_description TEXT,
    price REAL,
    package_volume INTEGER
);

