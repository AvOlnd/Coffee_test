import sqlite3

def create_connection():
    conn = sqlite3.connect('coffee_shop.db')
    return conn

def create_table():
    conn = create_connection()
    cursor = conn.cursor()
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS coffee (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            roast_level TEXT,
            grind_type TEXT,
            flavor_description TEXT,
            price REAL,
            package_volume INTEGER
        )
    ''')
    
    conn.commit()
    conn.close()

def insert_initial_data():
    conn = create_connection()
    cursor = conn.cursor()
    
    cursor.execute("SELECT COUNT(*) FROM coffee")
    count = cursor.fetchone()[0]
    
    if count == 0:
        coffees = [
            ('Эфиопия Сидамо', 'Светлая', 'зерна', 'Цитрус, ягоды, цветочные ноты', 850.00, 250),
            ('Колумбия Супремо', 'Средняя', 'молотый', 'Карамель, орехи, шоколад', 720.00, 250),
            ('Ямайка Блю Маунтин', 'Средняя', 'зерна', 'Сбалансированный, сладкий, ореховый', 2500.00, 200),
            ('Суматра Манделинг', 'Темная', 'зерна', 'Пряности, травы, полный вкус', 980.00, 300),
            ('Коста-Рика Тарразу', 'Светлая', 'молотый', 'Мед, цитрус, сладкое послевкусие', 890.00, 250),
            ('Бразилия Сантос', 'Средняя', 'зерна', 'Шоколад, орехи, низкая кислинка', 650.00, 500),
            ('Гватемала Уэуэтенанго', 'Светлая', 'зерна', 'Яблоко, карамель, цветы', 950.00, 250),
            ('Кения АА', 'Светлая', 'зерна', 'Черная смородина, цитрус, вино', 1200.00, 200),
            ('Индонезия Сулавеси', 'Темная', 'молотый', 'Пряности, табак, шоколад', 890.00, 300),
            ('Эфиопия Йргачеффе', 'Светлая', 'зерна', 'Жасмин, лимон, бергамот', 1100.00, 250)
        ]
        
        cursor.executemany('''
            INSERT INTO coffee (name, roast_level, grind_type, flavor_description, price, package_volume)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', coffees)
        
        conn.commit()
    
    conn.close()

def display_all_coffee():
    conn = create_connection()
    cursor = conn.cursor()
    
    cursor.execute('SELECT * FROM coffee')
    coffees = cursor.fetchall()
    
    for coffee in coffees:
        print(f"{coffee[0]}: {coffee[1]}, {coffee[2]}, {coffee[3]}, {coffee[4]}, {coffee[5]} руб., {coffee[6]}г")
    
    conn.close()

def add_new_coffee():
    name = input("Название: ")
    roast_level = input("Обжарка: ")
    grind_type = input("Помол: ")
    flavor_description = input("Вкус: ")
    price = float(input("Цена: "))
    package_volume = int(input("Объем: "))
    
    conn = create_connection()
    cursor = conn.cursor()
    
    cursor.execute('''
        INSERT INTO coffee (name, roast_level, grind_type, flavor_description, price, package_volume)
        VALUES (?, ?, ?, ?, ?, ?)
    ''', (name, roast_level, grind_type, flavor_description, price, package_volume))
    
    conn.commit()
    conn.close()

def update_coffee():
    display_all_coffee()
    
    coffee_id = int(input("\nID для изменения: "))
    
    conn = create_connection()
    cursor = conn.cursor()
    
    cursor.execute('SELECT * FROM coffee WHERE id = ?', (coffee_id,))
    coffee = cursor.fetchone()
    
    if not coffee:
        print("Не найден")
        conn.close()
        return
    
    print("\n1. Название")
    print("2. Обжарка")
    print("3. Помол")
    print("4. Вкус")
    print("5. Цена")
    print("6. Объем")
    
    choice = int(input("Выбор: "))
    new_value = input("Новое значение: ")
    
    fields = {
        1: ('name', new_value),
        2: ('roast_level', new_value),
        3: ('grind_type', new_value),
        4: ('flavor_description', new_value),
        5: ('price', float(new_value)),
        6: ('package_volume', int(new_value))
    }
    
    if choice in fields:
        field_name, field_value = fields[choice]
        cursor.execute(f'UPDATE coffee SET {field_name} = ? WHERE id = ?', (field_value, coffee_id))
        conn.commit()
    
    conn.close()

def main():
    create_table()
    insert_initial_data()
    
    while True:
        print("\n1. Показать весь кофе")
        print("2. Добавить новый кофе")
        print("3. Изменить кофе")
        print("4. Выход")
        
        choice = input("Выберите действие: ")
        
        if choice == '1':
            display_all_coffee()
        elif choice == '2':
            add_new_coffee()
        elif choice == '3':
            update_coffee()
        elif choice == '4':
            break

if __name__ == "__main__":
    main()
